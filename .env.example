# ---------------------------------------------------------------
# Voxly — environment variables reference
# Copy to .env for local development.  Never commit .env itself.
# ---------------------------------------------------------------

# --- Database (leave blank to use local SQLite) ---
TURSO_URL=libsql://your-db-name-your-username.turso.io
TURSO_TOKEN=your-turso-auth-token-here

# --- JWT Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
VOXLY_JWT_SECRET=replace-with-a-long-random-string
VOXLY_JWT_ALGORITHM=HS256
VOXLY_JWT_EXPIRES_MINUTES=60
VOXLY_JWT_REFRESH_DAYS=7

# --- CORS (comma-separated list of allowed frontend origins) ---
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# --- Flask ---
FLASK_ENV=production
PORT=5000

# --- Feature flags ---
VOXLY_COMMAND_LOGGING_ENABLED=false
VOXLY_SKIP_AUTOCREATE=false
