# Backend configuration
VOXLY_JWT_SECRET=replace-with-a-32-byte-hex-or-long-random-string
VOXLY_COMMAND_LOGGING_ENABLED=false
VOXLY_SKIP_AUTOCREATE=false

# Set to "production" to enable the JWT secret guard and other production behaviors
# FLASK_ENV=production

# Frontend build-time configuration
# Set to your domain so frontend can call the API (production build-time)
# REACT_APP_API_URL=https://your-domain.example.com/

# SECURITY: Do NOT commit a filled `.env` file to git. This example is safe to commit.
