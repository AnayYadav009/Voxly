# Voxly environment variables reference.
# Copy this file to .env for local development. Never commit .env.

# Database. Leave blank to use local SQLite.
DATABASE_URL=sqlite:///expenses.db
TURSO_URL=
TURSO_TOKEN=
REDIS_URL=redis://localhost:6379/0

# JWT authentication.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
VOXLY_JWT_SECRET=replace-with-a-random-64-character-secret
VOXLY_JWT_ALGORITHM=HS256
VOXLY_JWT_EXPIRES_MINUTES=60
VOXLY_JWT_REFRESH_DAYS=7

# CORS. Use a comma-separated list of allowed frontend origins.
VOXLY_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.example.com

# Flask.
FLASK_ENV=development
PORT=5000

# Optional Groq integration.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_INSIGHT_MODEL=llama-3.3-70b-versatile

# Feature flags.
VOXLY_COMMAND_LOGGING_ENABLED=false
VOXLY_SKIP_AUTOCREATE=false
